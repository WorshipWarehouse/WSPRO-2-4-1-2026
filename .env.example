# ─── Owner ───
# The email address that owns this instance.
# Only this email can access Owner Settings (API keys, secrets).
OWNER_EMAIL=

# ─── Authentication ───
# Secret key for signing JWT tokens. Change this to a long random string.
JWT_SECRET="your-super-secret-key"

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_SINGLE=
STRIPE_PRICE_ID_ORG=

# ─── Google OAuth ───
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ─── Apple Sign-In ───
# https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=

# ─── Application ───
APP_URL=
NODE_ENV="development"
