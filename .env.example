# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret key for signing JSON Web Tokens (auth sessions).
# MUST be changed in production to a random, high-entropy string.
JWT_SECRET="your-super-secret-key"

# NODE_ENV: Environment mode (development or production).
NODE_ENV="development"

# Stripe API Keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_SINGLE=
STRIPE_PRICE_ID_ORG=

# Google OAuth (for Sign in with Google)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Apple Sign-In
# Create a Service ID at https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=
